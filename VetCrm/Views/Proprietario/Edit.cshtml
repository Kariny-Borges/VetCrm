@model VetCrm.Models.Proprietario

@{
    ViewData["Title"] = "Editar Proprietario";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Editar Proprietario</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">← Voltar</a>
</div>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <input type="hidden" asp-for="Id" />

            <div class="form-group mb-3">
                <label asp-for="Nome">Nome</label>
                <input asp-for="Nome" class="form-control" />
                <span asp-validation-for="Nome" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="CPF">CPF</label>
                <input asp-for="CPF" class="form-control" />
                <span asp-validation-for="CPF" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="DataCadastro">Data de Cadastro</label>
                <input asp-for="DataCadastro" class="form-control" type="date" />
                <span asp-validation-for="DataCadastro" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="EnderecoId">Endereco</label>
                <select asp-for="EnderecoId" class="form-select" asp-items="ViewBag.EnderecoId">
                    <option value="">Nenhum (opcional)</option>
                </select>
                <span asp-validation-for="EnderecoId" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2">
                <input type="submit" value="Salvar" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
