@model VetCrm.Models.Proprietario

@{
    ViewData["Title"] = "Novo Proprietário";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Novo Proprietário</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">← Voltar</a>
</div>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="form-group mb-3">
                <label asp-for="Nome">Nome</label>
                <input asp-for="Nome" class="form-control" placeholder="Nome do proprietário" />
                <span asp-validation-for="Nome" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="CPF">CPF</label>
                <input asp-for="CPF" class="form-control mask-cpf" placeholder="000.000.000-00" maxlength="14" />
                <span asp-validation-for="CPF" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="DataCadastro">Data de Cadastro</label>
                <input asp-for="DataCadastro" class="form-control" type="date" />
                <span asp-validation-for="DataCadastro" class="text-danger"></span>
            </div>

            <hr />
            <h5>Endereco</h5>

            <div class="row">
                <div class="col-md-4 form-group mb-3">
                    <label>CEP</label>
                    <input name="endereco.CEP" id="cep" class="form-control mask-cep" placeholder="00000-000" maxlength="9" />
                </div>
            </div>
            <div class="row">
                <div class="col-md-8 form-group mb-3">
                    <label>Logradouro</label>
                    <input name="endereco.Logradouro" id="logradouro" class="form-control" placeholder="Rua, Av, Travessa..." />
                </div>
                <div class="col-md-4 form-group mb-3">
                    <label>Numero</label>
                    <input name="endereco.Numero" class="form-control" placeholder="123" />
                </div>
            </div>
            <div class="form-group mb-3">
                <label>Complemento</label>
                <input name="endereco.Complemento" id="complemento" class="form-control" placeholder="Apto, Bloco, Sala... (opcional)" />
            </div>
            <div class="row">
                <div class="col-md-4 form-group mb-3">
                    <label>Bairro</label>
                    <input name="endereco.Bairro" id="bairro" class="form-control" placeholder="Bairro" />
                </div>
                <div class="col-md-5 form-group mb-3">
                    <label>Cidade</label>
                    <input name="endereco.Cidade" id="cidade" class="form-control" placeholder="Cidade" />
                </div>
                <div class="col-md-3 form-group mb-3">
                    <label>Estado</label>
                    <input name="endereco.Estado" id="uf" class="form-control" placeholder="UF" maxlength="2" />
                </div>
            </div>

            <div class="d-flex gap-2">
                <input type="submit" value="Salvar" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
