@model VetCrm.Models.Proprietario

@{
    ViewData["Title"] = "Excluir Proprietario";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Excluir Proprietario</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">← Voltar</a>
</div>

<div class="alert alert-warning">
    Tem certeza que deseja excluir este proprietario?
</div>

<div class="row">
    <div class="col-md-6">
        <dl class="row">
            <dt class="col-sm-4">Nome</dt>
            <dd class="col-sm-8">@Model.Nome</dd>
            <dt class="col-sm-4">CPF</dt>
            <dd class="col-sm-8">@Model.CPF</dd>
            <dt class="col-sm-4">Data Cadastro</dt>
            <dd class="col-sm-8">@Model.DataCadastro.ToString("dd/MM/yyyy")</dd>
            <dt class="col-sm-4">Endereco</dt>
            <dd class="col-sm-8">@(Model.Endereco != null ? $"{Model.Endereco.Logradouro}, {Model.Endereco.Numero}" : "—")</dd>
        </dl>

        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />
            <div class="d-flex gap-2">
                <input type="submit" value="Excluir" class="btn btn-danger" />
                <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>
