@model VetCrm.Models.Estabelecimento

@{
    ViewData["Title"] = "Editar Estabelecimento";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Editar Estabelecimento</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">← Voltar</a>
</div>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <input type="hidden" asp-for="Id" />

            <div class="form-group mb-3">
                <label asp-for="Nome">Nome</label>
                <input asp-for="Nome" class="form-control" />
                <span asp-validation-for="Nome" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="CNPJ">CNPJ</label>
                <input asp-for="CNPJ" class="form-control mask-cnpj" maxlength="18" />
                <span asp-validation-for="CNPJ" class="text-danger"></span>
            </div>

            <input type="hidden" asp-for="EnderecoId" />
            <hr />
            <h5>Endereco</h5>

            <div class="row">
                <div class="col-md-4 form-group mb-3">
                    <label>CEP</label>
                    <input name="endereco.CEP" id="cep" class="form-control mask-cep" value="@Model?.Endereco?.CEP" maxlength="9" />
                </div>
            </div>
            <div class="row">
                <div class="col-md-8 form-group mb-3">
                    <label>Logradouro</label>
                    <input name="endereco.Logradouro" id="logradouro" class="form-control" value="@Model?.Endereco?.Logradouro" />
                </div>
                <div class="col-md-4 form-group mb-3">
                    <label>Numero</label>
                    <input name="endereco.Numero" class="form-control" value="@Model?.Endereco?.Numero" />
                </div>
            </div>
            <div class="form-group mb-3">
                <label>Complemento</label>
                <input name="endereco.Complemento" id="complemento" class="form-control" value="@Model?.Endereco?.Complemento" />
            </div>
            <div class="row">
                <div class="col-md-4 form-group mb-3">
                    <label>Bairro</label>
                    <input name="endereco.Bairro" id="bairro" class="form-control" value="@Model?.Endereco?.Bairro" />
                </div>
                <div class="col-md-5 form-group mb-3">
                    <label>Cidade</label>
                    <input name="endereco.Cidade" id="cidade" class="form-control" value="@Model?.Endereco?.Cidade" />
                </div>
                <div class="col-md-3 form-group mb-3">
                    <label>Estado</label>
                    <input name="endereco.Estado" id="uf" class="form-control" value="@Model?.Endereco?.Estado" maxlength="2" />
                </div>
            </div>

            <div class="d-flex gap-2">
                <input type="submit" value="Salvar" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
