@model VetCrm.Models.Estabelecimento

@{
    ViewData["Title"] = "Novo Estabelecimento";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Novo Estabelecimento</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">← Voltar</a>
</div>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="form-group mb-3">
                <label asp-for="Nome">Nome</label>
                <input asp-for="Nome" class="form-control" placeholder="Nome do estabelecimento" />
                <span asp-validation-for="Nome" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="CNPJ">CNPJ</label>
                <input asp-for="CNPJ" class="form-control" placeholder="00.000.000/0000-00" />
                <span asp-validation-for="CNPJ" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="EnderecoId">Endereco</label>
                <select asp-for="EnderecoId" class="form-select" asp-items="ViewBag.EnderecoId">
                    <option value="">Nenhum (opcional)</option>
                </select>
            </div>

            <div class="d-flex gap-2">
                <input type="submit" value="Salvar" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
