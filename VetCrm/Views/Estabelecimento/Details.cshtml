@model VetCrm.Models.Estabelecimento

@{
    ViewData["Title"] = "Detalhes do Estabelecimento";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Detalhes do Estabelecimento</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">← Voltar</a>
</div>

<div class="row">
    <div class="col-md-6">
        <dl class="row">
            <dt class="col-sm-4">Nome</dt>
            <dd class="col-sm-8">@Model.Nome</dd>
            <dt class="col-sm-4">CNPJ</dt>
            <dd class="col-sm-8">@Model.CNPJ</dd>
            <dt class="col-sm-4">Endereco</dt>
            <dd class="col-sm-8">@(Model.Endereco != null ? $"{Model.Endereco.Logradouro}, {Model.Endereco.Numero}" : "—")</dd>
        </dl>

        <div class="d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-success">Editar</a>
            <a asp-action="Index" class="btn btn-outline-secondary">Voltar</a>
        </div>
    </div>
</div>
