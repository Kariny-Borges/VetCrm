@model VetCrm.Models.Prontuario

@{
    ViewData["Title"] = "Excluir Prontuario";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Excluir Prontuario</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">← Voltar</a>
</div>

<div class="alert alert-warning">
    Tem certeza que deseja excluir este prontuario?
</div>

@if (TempData["ErroExclusao"] != null)
{
    <div class="alert alert-danger">
        @TempData["ErroExclusao"]
    </div>
}

<div class="row">
    <div class="col-md-6">
        <dl class="row">
            <dt class="col-sm-4">Data Registro</dt>
            <dd class="col-sm-8">@Model.DataRegistro.ToString("dd/MM/yyyy")</dd>
            <dt class="col-sm-4">Paciente</dt>
            <dd class="col-sm-8">@Model.Paciente?.Nome</dd>
            <dt class="col-sm-4">Descricao</dt>
            <dd class="col-sm-8">@Model.Descricao</dd>
            <dt class="col-sm-4">Diagnostico</dt>
            <dd class="col-sm-8">@Model.Diagnostico</dd>
            <dt class="col-sm-4">Tratamento</dt>
            <dd class="col-sm-8">@Model.Tratamento</dd>
        </dl>

        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />
            <div class="d-flex gap-2">
                <input type="submit" value="Excluir" class="btn btn-danger" />
                <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>
