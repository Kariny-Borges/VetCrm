@model IEnumerable<VetCrm.Models.Prontuario>

@{
    ViewData["Title"] = "Prontuarios";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>📄 Prontuarios</h2>
    <a asp-action="Create" class="btn btn-primary">+ Novo Prontuario</a>
</div>

<table class="table table-hover">
    <thead>
        <tr>
            <th>Data Registro</th>
            <th>Diagnostico</th>
            <th>Tratamento</th>
            <th>Paciente</th>
            <th>Acoes</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.DataRegistro.ToString("dd/MM/yyyy")</td>
                <td>@item.Diagnostico</td>
                <td>@item.Tratamento</td>
                <td>@item.Paciente?.Nome</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-success">Editar</a>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Detalhes</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Excluir</a>
                </td>
            </tr>
        }
    </tbody>
</table>
