@model VetCrm.Models.Prontuario

@{
    ViewData["Title"] = "Editar Prontuario";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Editar Prontuario</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">← Voltar</a>
</div>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <input type="hidden" asp-for="Id" />

            <div class="form-group mb-3">
                <label asp-for="DataRegistro">Data de Registro</label>
                <input asp-for="DataRegistro" class="form-control" type="date" />
                <span asp-validation-for="DataRegistro" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="PacienteId">Paciente</label>
                <select asp-for="PacienteId" class="form-select" asp-items="ViewBag.PacienteId">
                    <option value="">Selecione o paciente...</option>
                </select>
                <span asp-validation-for="PacienteId" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="ConsultaId">Consulta</label>
                <select asp-for="ConsultaId" class="form-select" asp-items="ViewBag.ConsultaId">
                    <option value="">Selecione a consulta...</option>
                </select>
                <span asp-validation-for="ConsultaId" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Descricao">Descricao</label>
                <textarea asp-for="Descricao" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Descricao" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Diagnostico">Diagnostico</label>
                <textarea asp-for="Diagnostico" class="form-control" rows="2"></textarea>
                <span asp-validation-for="Diagnostico" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Tratamento">Tratamento</label>
                <textarea asp-for="Tratamento" class="form-control" rows="2"></textarea>
                <span asp-validation-for="Tratamento" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2">
                <input type="submit" value="Salvar" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
