@model IEnumerable<VetCrm.Models.Categoria>

@{
    ViewData["Title"] = "Categorias";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>🏷️ Categorias</h2>
    <a asp-action="Create" class="btn btn-primary">+ Nova Categoria</a>
</div>

<table class="table table-hover">
    <thead>
        <tr>
            <th>Nome</th>
            <th>Ações</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var categoria in Model)
        {
            <tr>
                <td>@categoria.Nome</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@categoria.Id" class="btn btn-sm btn-outline-success">Editar</a>
                    <a asp-action="Delete" asp-route-id="@categoria.Id" class="btn btn-sm btn-outline-danger">Excluir</a>
                </td>
            </tr>
        }
    </tbody>
</table>
