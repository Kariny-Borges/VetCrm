@model IEnumerable<VetCrm.Models.PacienteVacina>

@{
    ViewData["Title"] = "Vacinacoes";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>💉 Vacinacoes</h2>
    <a asp-action="Create" class="btn btn-primary">+ Nova Vacinacao</a>
</div>

<table class="table table-hover">
    <thead>
        <tr>
            <th>Paciente</th>
            <th>Vacina</th>
            <th>Data Aplicacao</th>
            <th>Proxima Dose</th>
            <th>Acoes</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Paciente?.Nome</td>
                <td>@item.Vacina?.Nome</td>
                <td>@item.DataAplicacao.ToString("dd/MM/yyyy")</td>
                <td>@item.DataProximaDose.ToString("dd/MM/yyyy")</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-success">Editar</a>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Detalhes</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Excluir</a>
                </td>
            </tr>
        }
    </tbody>
</table>
