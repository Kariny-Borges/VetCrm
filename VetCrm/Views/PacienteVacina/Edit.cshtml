@model VetCrm.Models.PacienteVacina

@{
    ViewData["Title"] = "Editar Vacinacao";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Editar Vacinacao</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">← Voltar</a>
</div>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <input type="hidden" asp-for="Id" />

            <div class="form-group mb-3">
                <label asp-for="PacienteId">Paciente</label>
                <select asp-for="PacienteId" class="form-select" asp-items="ViewBag.PacienteId">
                    <option value="">Selecione o paciente...</option>
                </select>
                <span asp-validation-for="PacienteId" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="VacinaId">Vacina</label>
                <select asp-for="VacinaId" class="form-select" asp-items="ViewBag.VacinaId">
                    <option value="">Selecione a vacina...</option>
                </select>
                <span asp-validation-for="VacinaId" class="text-danger"></span>
            </div>

            <div class="row">
                <div class="col-md-6 form-group mb-3">
                    <label asp-for="DataAplicacao">Data de Aplicacao</label>
                    <input asp-for="DataAplicacao" class="form-control" type="date" />
                    <span asp-validation-for="DataAplicacao" class="text-danger"></span>
                </div>
                <div class="col-md-6 form-group mb-3">
                    <label asp-for="DataProximaDose">Proxima Dose</label>
                    <input asp-for="DataProximaDose" class="form-control" type="date" />
                    <span asp-validation-for="DataProximaDose" class="text-danger"></span>
                </div>
            </div>

            <div class="d-flex gap-2">
                <input type="submit" value="Salvar" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
