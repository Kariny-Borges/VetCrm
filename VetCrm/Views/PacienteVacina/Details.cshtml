@model VetCrm.Models.PacienteVacina

@{
    ViewData["Title"] = "Detalhes da Vacinacao";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Detalhes da Vacinacao</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">← Voltar</a>
</div>

<div class="row">
    <div class="col-md-6">
        <dl class="row">
            <dt class="col-sm-4">Paciente</dt>
            <dd class="col-sm-8">@Model.Paciente?.Nome</dd>
            <dt class="col-sm-4">Vacina</dt>
            <dd class="col-sm-8">@Model.Vacina?.Nome</dd>
            <dt class="col-sm-4">Data Aplicacao</dt>
            <dd class="col-sm-8">@Model.DataAplicacao.ToString("dd/MM/yyyy")</dd>
            <dt class="col-sm-4">Proxima Dose</dt>
            <dd class="col-sm-8">@Model.DataProximaDose.ToString("dd/MM/yyyy")</dd>
        </dl>

        <div class="d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-success">Editar</a>
            <a asp-action="Index" class="btn btn-outline-secondary">Voltar</a>
        </div>
    </div>
</div>
