@model VetCrm.Models.Consulta

@{
    ViewData["Title"] = "Editar Consulta";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Editar Consulta</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">← Voltar</a>
</div>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <input type="hidden" asp-for="Id" />

            <div class="form-group mb-3">
                <label asp-for="DataConsulta">Data da Consulta</label>
                <input asp-for="DataConsulta" class="form-control" type="date" />
                <span asp-validation-for="DataConsulta" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="TipoConsultaId">Tipo de Consulta</label>
                <select asp-for="TipoConsultaId" class="form-select" asp-items="ViewBag.TipoConsultaId">
                    <option value="">Selecione...</option>
                </select>
                <span asp-validation-for="TipoConsultaId" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="PacienteId">Paciente</label>
                <select asp-for="PacienteId" class="form-select" asp-items="ViewBag.PacienteId">
                    <option value="">Selecione o paciente...</option>
                </select>
                <span asp-validation-for="PacienteId" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="VeterinarioId">Veterinario</label>
                <select asp-for="VeterinarioId" class="form-select" asp-items="ViewBag.VeterinarioId">
                    <option value="">Selecione o veterinario...</option>
                </select>
                <span asp-validation-for="VeterinarioId" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Observacoes">Observacoes</label>
                <textarea asp-for="Observacoes" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Observacoes" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2">
                <input type="submit" value="Salvar" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
