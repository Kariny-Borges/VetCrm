@model IEnumerable<VetCrm.Models.Consulta>

@{
    ViewData["Title"] = "Consultas";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>📋 Consultas</h2>
    <a asp-action="Create" class="btn btn-primary">+ Nova Consulta</a>
</div>

<table class="table table-hover">
    <thead>
        <tr>
            <th>Data</th>
            <th>Tipo</th>
            <th>Paciente</th>
            <th>Veterinario</th>
            <th>Observacoes</th>
            <th>Acoes</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.DataConsulta.ToString("dd/MM/yyyy")</td>
                <td>@item.TipoConsulta</td>
                <td>@item.Paciente?.Nome</td>
                <td>@item.Veterinario?.Nome</td>
                <td>@item.Observacoes</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-success">Editar</a>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Detalhes</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Excluir</a>
                </td>
            </tr>
        }
    </tbody>
</table>
