@model VetCrm.Models.Consulta

@{
    ViewData["Title"] = "Detalhes da Consulta";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Detalhes da Consulta</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">← Voltar</a>
</div>

<div class="row">
    <div class="col-md-6">
        <dl class="row">
            <dt class="col-sm-4">Data</dt>
            <dd class="col-sm-8">@Model.DataConsulta.ToString("dd/MM/yyyy")</dd>
            <dt class="col-sm-4">Tipo</dt>
            <dd class="col-sm-8">@Model.TipoConsulta</dd>
            <dt class="col-sm-4">Paciente</dt>
            <dd class="col-sm-8">@Model.Paciente?.Nome</dd>
            <dt class="col-sm-4">Veterinario</dt>
            <dd class="col-sm-8">@Model.Veterinario?.Nome</dd>
            <dt class="col-sm-4">Observacoes</dt>
            <dd class="col-sm-8">@Model.Observacoes</dd>
        </dl>

        <div class="d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-success">Editar</a>
            <a asp-action="Index" class="btn btn-outline-secondary">Voltar</a>
        </div>
    </div>
</div>
