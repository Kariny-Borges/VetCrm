<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - VetCrm</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/VetCrm.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark bg-dark border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" asp-area="" asp-controller="Home" asp-action="Index">🐾 VetCrm</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Paciente" asp-action="Index">🐶 Pacientes</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Consulta" asp-action="Index">📋 Consultas</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Prontuario" asp-action="Index">📁 Prontuários</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="PacienteVacina" asp-action="Index">💉 Vacinas</a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                ⚙️ Cadastros
                            </a>
                            <ul class="dropdown-menu dropdown-menu-dark">
                                <li><a class="dropdown-item" asp-controller="Proprietario" asp-action="Index">Proprietários</a></li>
                                <li><a class="dropdown-item" asp-controller="Veterinario" asp-action="Index">Veterinários</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" asp-controller="Especie" asp-action="Index">Espécies</a></li>
                                <li><a class="dropdown-item" asp-controller="Raca" asp-action="Index">Raças</a></li>
                                <li><a class="dropdown-item" asp-controller="Vacina" asp-action="Index">Vacinas</a></li>
                                <li><a class="dropdown-item" asp-controller="Contato" asp-action="Index">Contatos</a></li>
                            </ul>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-4">
        <div class="container py-2">
            &copy; 2026 - VetCrm
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>