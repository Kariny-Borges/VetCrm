@model IEnumerable<VetCrm.Models.Contato>

@{
    ViewData["Title"] = "Contatos";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>📞 Contatos</h2>
    <a asp-action="Create" class="btn btn-primary">+ Novo Contato</a>
</div>

<table class="table table-hover">
    <thead>
        <tr>
            <th>Tipo</th>
            <th>Valor</th>
            <th>Acoes</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Tipo</td>
                <td>@item.Valor</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-success">Editar</a>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Detalhes</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Excluir</a>
                </td>
            </tr>
        }
    </tbody>
</table>
