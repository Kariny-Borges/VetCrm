@model VetCrm.Models.Contato

@{
    ViewData["Title"] = "Novo Contato";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>📞 Novo Contato</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">← Voltar</a>
</div>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="form-group mb-3">
                <label asp-for="Tipo">Tipo</label>
                <select asp-for="Tipo" class="form-select">
                    <option value="">Selecione...</option>
                    <option value="Telefone">Telefone</option>
                    <option value="Celular">Celular</option>
                    <option value="Email">Email</option>
                </select>
                <span asp-validation-for="Tipo" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Valor">Valor</label>
                <input asp-for="Valor" class="form-control" placeholder="Ex: (11) 99999-9999" />
                <span asp-validation-for="Valor" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2">
                <input type="submit" value="Salvar" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
