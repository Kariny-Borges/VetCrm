@model VetCrm.Models.Contato

@{
    ViewData["Title"] = "Excluir Contato";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Excluir Contato</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">← Voltar</a>
</div>

<div class="alert alert-warning">
    Tem certeza que deseja excluir este contato?
</div>

@if (TempData["ErroExclusao"] != null)
{
    <div class="alert alert-danger">
        @TempData["ErroExclusao"]
    </div>
}

<div class="row">
    <div class="col-md-6">
        <dl class="row">
            <dt class="col-sm-4">Tipo</dt>
            <dd class="col-sm-8">@Model.Tipo</dd>
            <dt class="col-sm-4">Valor</dt>
            <dd class="col-sm-8">@Model.Valor</dd>
        </dl>

        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />
            <div class="d-flex gap-2">
                <input type="submit" value="Excluir" class="btn btn-danger" />
                <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>
