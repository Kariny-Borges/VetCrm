@model VetCrm.Models.Raca

@{
    ViewData["Title"] = "Nova Raca";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>🐕 Nova Raca</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">← Voltar</a>
</div>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="form-group mb-3">
                <label asp-for="Nome">Nome</label>
                <input asp-for="Nome" class="form-control" placeholder="Nome da raca" />
                <span asp-validation-for="Nome" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="EspecieId">Especie</label>
                <select asp-for="EspecieId" class="form-select" asp-items="ViewBag.EspecieId">
                    <option value="">Selecione a especie...</option>
                </select>
                <span asp-validation-for="EspecieId" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2">
                <input type="submit" value="Salvar" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
