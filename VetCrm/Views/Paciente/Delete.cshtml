@model VetCrm.Models.Paciente

@{
    ViewData["Title"] = "Excluir Paciente";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Excluir Paciente</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">← Voltar</a>
</div>

<div class="alert alert-warning">
    Tem certeza que deseja excluir este paciente?
</div>

@if (TempData["ErroExclusao"] != null)
{
    <div class="alert alert-danger">
        @TempData["ErroExclusao"]
    </div>
}

<div class="row">
    <div class="col-md-6">
        <dl class="row">
            <dt class="col-sm-4">Nome</dt>
            <dd class="col-sm-8">@Model.Nome</dd>
            <dt class="col-sm-4">Idade</dt>
            <dd class="col-sm-8">@Model.Idade anos</dd>
            <dt class="col-sm-4">Sexo</dt>
            <dd class="col-sm-8">@Model.Sexo</dd>
            <dt class="col-sm-4">Peso</dt>
            <dd class="col-sm-8">@Model.Peso kg</dd>
            <dt class="col-sm-4">Data Cadastro</dt>
            <dd class="col-sm-8">@Model.DataCadastro.ToString("dd/MM/yyyy")</dd>
            <dt class="col-sm-4">Proprietario</dt>
            <dd class="col-sm-8">@Model.Proprietario?.Nome</dd>
            <dt class="col-sm-4">Especie</dt>
            <dd class="col-sm-8">@Model.Especie?.Nome</dd>
            <dt class="col-sm-4">Raca</dt>
            <dd class="col-sm-8">@Model.Raca?.Nome</dd>
        </dl>

        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />
            <div class="d-flex gap-2">
                <input type="submit" value="Excluir" class="btn btn-danger" />
                <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>
