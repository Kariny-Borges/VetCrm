@model VetCrm.Models.Paciente

@{
    ViewData["Title"] = "Editar Paciente";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Editar Paciente</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">← Voltar</a>
</div>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <input type="hidden" asp-for="Id" />

            <div class="form-group mb-3">
                <label asp-for="Nome">Nome</label>
                <input asp-for="Nome" class="form-control" />
                <span asp-validation-for="Nome" class="text-danger"></span>
            </div>

            <div class="row">
                <div class="col-md-6 form-group mb-3">
                    <label asp-for="Idade">Idade</label>
                    <input asp-for="Idade" class="form-control" />
                    <span asp-validation-for="Idade" class="text-danger"></span>
                </div>
                <div class="col-md-6 form-group mb-3">
                    <label asp-for="Peso">Peso (kg)</label>
                    <input asp-for="Peso" class="form-control" />
                    <span asp-validation-for="Peso" class="text-danger"></span>
                </div>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Sexo">Sexo</label>
                <select asp-for="Sexo" class="form-select">
                    <option value="">Selecione...</option>
                    <option value="Macho">Macho</option>
                    <option value="Fêmea">Fêmea</option>
                </select>
                <span asp-validation-for="Sexo" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="DataCadastro">Data de Cadastro</label>
                <input asp-for="DataCadastro" class="form-control" type="date" />
                <span asp-validation-for="DataCadastro" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="ProprietarioId">Proprietário</label>
                <select asp-for="ProprietarioId" class="form-select" asp-items="ViewBag.ProprietarioId">
                    <option value="">Selecione o proprietário...</option>
                </select>
                <span asp-validation-for="ProprietarioId" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="EspecieId">Espécie</label>
                <select asp-for="EspecieId" class="form-select" asp-items="ViewBag.EspecieId">
                    <option value="">Selecione a espécie...</option>
                </select>
                <span asp-validation-for="EspecieId" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="RacaId">Raça</label>
                <select asp-for="RacaId" class="form-select" asp-items="ViewBag.RacaId">
                    <option value="">Selecione a raça...</option>
                </select>
                <span asp-validation-for="RacaId" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2">
                <input type="submit" value="Salvar" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
