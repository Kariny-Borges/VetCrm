@model VetCrm.Models.Usuario

@{
    ViewData["Title"] = "Excluir Usuario";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Excluir Usuario</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">← Voltar</a>
</div>

<div class="alert alert-warning">
    Tem certeza que deseja excluir o usuario <strong>@Model.Nome</strong>?
</div>

@if (TempData["ErroExclusao"] != null)
{
    <div class="alert alert-danger">
        @TempData["ErroExclusao"]
    </div>
}

<div class="row">
    <div class="col-md-6">
        <dl class="row">
            <dt class="col-sm-4">Nome</dt>
            <dd class="col-sm-8">@Model.Nome</dd>
            <dt class="col-sm-4">Endereco</dt>
            <dd class="col-sm-8">@(Model.Endereco != null ? $"{Model.Endereco.Logradouro}, {Model.Endereco.Numero}" : "—")</dd>
        </dl>

        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />
            <div class="d-flex gap-2">
                <input type="submit" value="Excluir" class="btn btn-danger" />
                <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>
