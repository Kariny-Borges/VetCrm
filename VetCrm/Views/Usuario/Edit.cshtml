@model VetCrm.Models.Usuario

@{
    ViewData["Title"] = "Editar Usuario";
}

<h1>Editar Usuario</h1>

<form asp-action="Edit">
    <div asp-validation-summary="All" class="text-danger"></div>
    <input type="hidden" asp-for="Id" />
    <div class="mb-3">
        <label asp-for="Login" class="form-label">Login</label>
        <input asp-for="Login" class="form-control" />
        <span asp-validation-for="Login" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Senha" class="form-label">Senha</label>
        <input asp-for="Senha" type="password" class="form-control" />
        <span asp-validation-for="Senha" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Nome" class="form-label">Nome</label>
        <input asp-for="Nome" class="form-control" />
        <span asp-validation-for="Nome" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="CPF" class="form-label">CPF</label>
        <input asp-for="CPF" class="form-control mask-cpf" placeholder="000.000.000-00" maxlength="14" />
        <span asp-validation-for="CPF" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Email" class="form-label">Email</label>
        <input asp-for="Email" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Telefone" class="form-label">Telefone</label>
        <input asp-for="Telefone" class="form-control mask-telefone" placeholder="(00) 00000-0000" maxlength="15" />
    </div>

    <div class="mb-3">
        <label asp-for="Perfil" class="form-label">Perfil</label>
        <select asp-for="Perfil" class="form-select"
                asp-items="Html.GetEnumSelectList<VetCrm.Models.PerfilUsuario>()">
        </select>
    </div>

    <input type="hidden" asp-for="EnderecoId" />
    <hr />
    <h4>Endereco</h4>

    <div class="row">
        <div class="col-md-4 mb-3">
            <label class="form-label">CEP</label>
            <input name="endereco.CEP" id="cep" class="form-control mask-cep" value="@Model?.Endereco?.CEP" maxlength="9" />
        </div>
    </div>
    <div class="row">
        <div class="col-md-8 mb-3">
            <label class="form-label">Logradouro</label>
            <input name="endereco.Logradouro" id="logradouro" class="form-control" value="@Model?.Endereco?.Logradouro" />
        </div>
        <div class="col-md-4 mb-3">
            <label class="form-label">Numero</label>
            <input name="endereco.Numero" class="form-control" value="@Model?.Endereco?.Numero" />
        </div>
    </div>
    <div class="mb-3">
        <label class="form-label">Complemento</label>
        <input name="endereco.Complemento" id="complemento" class="form-control" value="@Model?.Endereco?.Complemento" />
    </div>
    <div class="row">
        <div class="col-md-4 mb-3">
            <label class="form-label">Bairro</label>
            <input name="endereco.Bairro" id="bairro" class="form-control" value="@Model?.Endereco?.Bairro" />
        </div>
        <div class="col-md-5 mb-3">
            <label class="form-label">Cidade</label>
            <input name="endereco.Cidade" id="cidade" class="form-control" value="@Model?.Endereco?.Cidade" />
        </div>
        <div class="col-md-3 mb-3">
            <label class="form-label">Estado</label>
            <input name="endereco.Estado" id="uf" class="form-control" value="@Model?.Endereco?.Estado" maxlength="2" />
        </div>
    </div>

    <button type="submit" class="btn btn-primary">Salvar</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>
