@model VetCrm.Models.Usuario

@{
    ViewData["Title"] = "Novo Usuario";
}

<h1>Novo Usuario</h1>

<form asp-action="Create">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="Login" class="form-label">Login</label>
        <input asp-for="Login" class="form-control" />
        <span asp-validation-for="Login" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Senha" class="form-label">Senha</label>
        <input asp-for="Senha" type="password" class="form-control" />
        <span asp-validation-for="Senha" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Nome" class="form-label">Nome</label>
        <input asp-for="Nome" class="form-control" />
        <span asp-validation-for="Nome" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="TipoPessoa" class="form-label">Tipo de Pessoa</label>
        <select asp-for="TipoPessoa" class="form-select" id="tipoPessoa"
                asp-items="Html.GetEnumSelectList<VetCrm.Models.TipoPessoa>()">
        </select>
    </div>

    <div class="mb-3">
        <label asp-for="Documento" class="form-label" id="labelDocumento">CPF</label>
        <input asp-for="Documento" class="form-control" id="inputDocumento" placeholder="000.000.000-00" maxlength="18" />
        <span asp-validation-for="Documento" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Email" class="form-label">Email</label>
        <input asp-for="Email" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Telefone" class="form-label">Telefone</label>
        <input asp-for="Telefone" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Perfil" class="form-label">Perfil</label>
        <select asp-for="Perfil" class="form-select"
                asp-items="Html.GetEnumSelectList<VetCrm.Models.PerfilUsuario>()">
        </select>
    </div>

    <hr />
    <h4>Endereco</h4>

    <div class="row">
        <div class="col-md-8 mb-3">
            <label class="form-label">Logradouro</label>
            <input name="Endereco.Logradouro" class="form-control" value="@Model?.Endereco?.Logradouro" />
        </div>
        <div class="col-md-4 mb-3">
            <label class="form-label">Numero</label>
            <input name="Endereco.Numero" class="form-control" value="@Model?.Endereco?.Numero" />
        </div>
    </div>

    <div class="row">
        <div class="col-md-4 mb-3">
            <label class="form-label">Bairro</label>
            <input name="Endereco.Bairro" class="form-control" value="@Model?.Endereco?.Bairro" />
        </div>
        <div class="col-md-4 mb-3">
            <label class="form-label">Cidade</label>
            <input name="Endereco.Cidade" class="form-control" value="@Model?.Endereco?.Cidade" />
        </div>
        <div class="col-md-2 mb-3">
            <label class="form-label">Estado</label>
            <input name="Endereco.Estado" class="form-control" value="@Model?.Endereco?.Estado" maxlength="2" />
        </div>
        <div class="col-md-2 mb-3">
            <label class="form-label">CEP</label>
            <input name="Endereco.CEP" class="form-control" value="@Model?.Endereco?.CEP" placeholder="00000-000" maxlength="9" />
        </div>
    </div>

    <hr />
    <h4>Estabelecimento</h4>

    <div class="mb-3">
        <label class="form-label">Vincular a um Estabelecimento</label>
        <select name="EstabelecimentoId" class="form-select">
            <option value="">-- Nenhum --</option>
            @foreach (var e in ViewBag.Estabelecimentos as List<VetCrm.Models.Estabelecimento> ?? new())
            {
                <option value="@e.Id">@e.Nome</option>
            }
        </select>
    </div>

    <button type="submit" class="btn btn-primary">Salvar</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var tipoPessoa = document.getElementById('tipoPessoa');
            var labelDoc = document.getElementById('labelDocumento');
            var inputDoc = document.getElementById('inputDocumento');

            function atualizarDocumento() {
                if (tipoPessoa.value === '2') {
                    labelDoc.textContent = 'CNPJ';
                    inputDoc.placeholder = '00.000.000/0000-00';
                    inputDoc.maxLength = 18;
                } else {
                    labelDoc.textContent = 'CPF';
                    inputDoc.placeholder = '000.000.000-00';
                    inputDoc.maxLength = 14;
                }
            }

            tipoPessoa.addEventListener('change', atualizarDocumento);
            atualizarDocumento();
        });
    </script>
}
