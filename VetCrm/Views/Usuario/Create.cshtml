@model VetCrm.Models.Usuario

@{
    ViewData["Title"] = "Novo Usuario";
}

<h1>Novo Usuario</h1>

@if (ViewBag.ErrosDebug != null && !string.IsNullOrWhiteSpace((string)ViewBag.ErrosDebug))
{
    <div class="alert alert-warning">
        <strong>Diagnóstico:</strong> @ViewBag.ErrosDebug
    </div>
}

<form asp-action="Create" method="post">
    <div asp-validation-summary="All" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="Login" class="form-label">Login</label>
        <input asp-for="Login" class="form-control" />
        <span asp-validation-for="Login" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Senha" class="form-label">Senha</label>
        <input asp-for="Senha" type="password" class="form-control" />
        <span asp-validation-for="Senha" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Nome" class="form-label">Nome</label>
        <input asp-for="Nome" class="form-control" />
        <span asp-validation-for="Nome" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="CPF" class="form-label">CPF</label>
        <input asp-for="CPF" class="form-control mask-cpf" placeholder="000.000.000-00" maxlength="14" />
        <span asp-validation-for="CPF" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Email" class="form-label">Email</label>
        <input asp-for="Email" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Telefone" class="form-label">Telefone</label>
        <input asp-for="Telefone" class="form-control mask-telefone" placeholder="(00) 00000-0000" maxlength="15" />
    </div>

    <div class="mb-3">
        <label asp-for="Perfil" class="form-label">Perfil</label>
        <select asp-for="Perfil" class="form-select"
                asp-items="Html.GetEnumSelectList<VetCrm.Models.PerfilUsuario>()">
        </select>
    </div>

    <hr />
    <h4>Endereco</h4>

    <div class="row">
        <div class="col-md-4 mb-3">
            <label class="form-label">CEP</label>
            <input name="endereco.CEP" id="cep" class="form-control mask-cep" placeholder="00000-000" maxlength="9" />
        </div>
    </div>
    <div class="row">
        <div class="col-md-8 mb-3">
            <label class="form-label">Logradouro</label>
            <input name="endereco.Logradouro" id="logradouro" class="form-control" placeholder="Rua, Av, Travessa..." />
        </div>
        <div class="col-md-4 mb-3">
            <label class="form-label">Numero</label>
            <input name="endereco.Numero" class="form-control" placeholder="123" />
        </div>
    </div>
    <div class="mb-3">
        <label class="form-label">Complemento</label>
        <input name="endereco.Complemento" id="complemento" class="form-control" placeholder="Apto, Bloco, Sala... (opcional)" />
    </div>
    <div class="row">
        <div class="col-md-4 mb-3">
            <label class="form-label">Bairro</label>
            <input name="endereco.Bairro" id="bairro" class="form-control" placeholder="Bairro" />
        </div>
        <div class="col-md-5 mb-3">
            <label class="form-label">Cidade</label>
            <input name="endereco.Cidade" id="cidade" class="form-control" placeholder="Cidade" />
        </div>
        <div class="col-md-3 mb-3">
            <label class="form-label">Estado</label>
            <input name="endereco.Estado" id="uf" class="form-control" placeholder="UF" maxlength="2" />
        </div>
    </div>

    <button type="submit" class="btn btn-primary">Salvar</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>
