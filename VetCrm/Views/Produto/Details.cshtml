@model VetCrm.Models.Produto

@{
    ViewData["Title"] = "Detalhes do Produto";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Detalhes do Produto</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">← Voltar</a>
</div>

<div class="row">
    <div class="col-md-6">
        <dl class="row">
            <dt class="col-sm-4">Nome</dt>
            <dd class="col-sm-8">@Model.Nome</dd>

            <dt class="col-sm-4">Categoria</dt>
            <dd class="col-sm-8">@Model.Categoria</dd>

            <dt class="col-sm-4">Quantidade</dt>
            <dd class="col-sm-8">@Model.Quantidade</dd>

            <dt class="col-sm-4">Preço</dt>
            <dd class="col-sm-8">@Model.Preco.ToString("C")</dd>
        </dl>

        <div class="d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-success">Editar</a>
            <a asp-action="Index" class="btn btn-outline-secondary">Voltar</a>
        </div>
    </div>
</div>
