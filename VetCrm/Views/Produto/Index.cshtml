@model IEnumerable<VetCrm.Models.Produto>

@{
    ViewData["Title"] = "Produtos";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>📦 Produtos</h2>
    <a asp-action="Create" class="btn btn-primary">+ Novo Produto</a>
</div>

<form asp-action="Index" method="get" class="mb-3">
    <div class="input-group" style="max-width: 400px;">
        <input type="text" name="busca" value="@ViewData["BuscaAtual"]" class="form-control" placeholder="Buscar por nome ou categoria..." />
        <button type="submit" class="btn btn-outline-primary">Buscar</button>
        @if (!string.IsNullOrEmpty(ViewData["BuscaAtual"]?.ToString()))
        {
            <a asp-action="Index" class="btn btn-outline-secondary">Limpar</a>
        }
    </div>
</form>

<table class="table table-hover">
    <thead>
        <tr>
            <th>Nome</th>
            <th>Categoria</th>
            <th>Quantidade</th>
            <th>Preço</th>
            <th>Ações</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var produto in Model)
        {
            <tr>
                <td>@produto.Nome</td>
                <td>@produto.Categoria?.Nome</td>
                <td>@produto.Quantidade</td>
                <td>@produto.Preco.ToString("C")</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@produto.Id" class="btn btn-sm btn-outline-success">Editar</a>
                    <a asp-action="Details" asp-route-id="@produto.Id" class="btn btn-sm btn-outline-secondary">Detalhes</a>
                    <a asp-action="Delete" asp-route-id="@produto.Id" class="btn btn-sm btn-outline-danger">Excluir</a>
                </td>
            </tr>
        }
    </tbody>
</table>
