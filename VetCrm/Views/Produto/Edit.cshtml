@model VetCrm.Models.Produto

@{
    ViewData["Title"] = "Editar Produto";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Editar Produto</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">← Voltar</a>
</div>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <input type="hidden" asp-for="Id" />

            <div class="form-group mb-3">
                <label asp-for="Nome">Nome</label>
                <input asp-for="Nome" class="form-control" />
                <span asp-validation-for="Nome" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Categoria">Categoria</label>
                <input asp-for="Categoria" class="form-control" />
                <span asp-validation-for="Categoria" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Quantidade">Quantidade</label>
                <input asp-for="Quantidade" class="form-control" type="number" min="0" />
                <span asp-validation-for="Quantidade" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Preco">Preço (R$)</label>
                <input asp-for="Preco" class="form-control" type="number" step="0.01" min="0" />
                <span asp-validation-for="Preco" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2">
                <input type="submit" value="Salvar" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
